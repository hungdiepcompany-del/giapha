{
  "name": "web-gia-pha",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check:foundation": "node scripts/check-project-foundation.cjs",
    "check:auth-permissions": "node scripts/check-auth-permissions.cjs",
    "check:people": "node scripts/check-people-foundation.cjs",
    "check:relationships": "node scripts/check-relationship-foundation.cjs",
    "check:tree-viewer": "node scripts/check-tree-viewer-foundation.cjs",
    "check:tree-editor": "node scripts/check-tree-editor-foundation.cjs",
    "check:public-privacy": "node scripts/check-public-privacy-foundation.cjs",
    "check:export-backup": "node scripts/check-export-backup-foundation.cjs",
    "check:revisions": "node scripts/check-revision-history-foundation.cjs",
    "check:import-json": "node scripts/check-import-json-foundation.cjs",
    "check:ui-polish": "node scripts/check-ui-polish-foundation.cjs",
    "check:deploy-readiness": "node scripts/check-deploy-readiness.cjs",
    "check:opennext-cloudflare": "node scripts/check-opennext-cloudflare-wiring.cjs",
    "check:env:safe": "node scripts/check-env-safe.cjs",
    "check:migrations": "node scripts/check-migrations-order.cjs"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@xyflow/react": "^12.11.0",
    "elkjs": "^0.11.1",
    "jszip": "^3.10.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.100.0"
  }
}
